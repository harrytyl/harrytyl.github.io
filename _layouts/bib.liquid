<div class="publication-card space-y-2">
  <div class="publication-entry">
    {{ reference }}
  </div>

  <div class="publication-meta flex flex-wrap gap-2">
    {% if entry.rank %}
    <span class="inline-flex items-center rounded-full bg-slate-100 text-slate-900 px-2 py-1 text-xs font-semibold dark:bg-slate-800 dark:text-slate-100">
      {{ entry.rank }}
    </span>
    {% endif %}

    {% if entry.first_author %}
    <span class="inline-flex items-center rounded-full bg-slate-100 text-slate-900 px-2 py-1 text-xs font-semibold dark:bg-slate-800 dark:text-slate-100">
      <i class="fa fa-user mr-1" aria-hidden="true"></i>
      First author
    </span>
    {% endif %}

    {% if entry.in_press %}
    <span class="inline-flex items-center rounded-full bg-slate-100 text-slate-900 px-2 py-1 text-xs font-semibold dark:bg-slate-800 dark:text-slate-100">
      <i class="fa fa-file-alt mr-1" aria-hidden="true"></i>
      In-press
    </span>
    {% endif %}
  </div>
</div>
